{
  "name": "charon6-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=SYS_ADMIN",
    "--device=/dev/net/tun",
    "--security-opt=seccomp=unconfined"
  ],
  "postCreateCommand": "sudo mkdir -p /dev/net && sudo mknod -m 666 /dev/net/tun c 10 200",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ]
}
